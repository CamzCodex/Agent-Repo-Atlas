{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Repo Index",
  "type": "object",
  "required": [
    "version",
    "generatedAt",
    "source",
    "entries"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}

