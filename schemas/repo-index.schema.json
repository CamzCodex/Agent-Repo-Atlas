{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Repo Atlas Index",
  "type": "object",
  "required": ["version", "generatedAt", "source", "entries"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "generatedFrom": { "type": "object" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "slug",
          "owner",
          "repo",
          "name",
          "url",
          "entryPath",
          "category",
          "type",
          "aliases",
          "stack",
          "tags",
          "summary",
          "primaryUseCases",
          "acquisitionMode",
          "riskLevel",
          "reviewRequiredBeforeUse",
          "recommendedAgentAction",
          "searchText",
          "license",
          "maintenanceState"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "slug": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "repo": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "minLength": 1 },
          "entryPath": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "aliases": { "type": "array" },
          "stack": { "type": "array" },
          "tags": { "type": "array" },
          "summary": { "type": "string", "minLength": 1 },
          "primaryUseCases": { "type": "array" },
          "acquisitionMode": { "type": "string", "minLength": 1 },
          "riskLevel": { "type": "string", "minLength": 1 },
          "reviewRequiredBeforeUse": { "type": "boolean" },
          "recommendedAgentAction": { "type": "string", "minLength": 1 },
          "searchText": { "type": "string", "minLength": 1 },
          "license": { "type": "string", "minLength": 1 },
          "maintenanceState": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}

