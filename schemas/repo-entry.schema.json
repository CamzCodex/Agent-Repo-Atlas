{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Repo Atlas Entry",
  "type": "object",
  "required": [
    "id",
    "slug",
    "owner",
    "repo",
    "name",
    "url",
    "entryPath",
    "category",
    "type",
    "aliases",
    "stack",
    "tags",
    "summary",
    "primaryUseCases",
    "agentUseInstruction",
    "acquisitionMode",
    "riskLevel",
    "riskFlags",
    "riskNotes",
    "reviewRequiredBeforeUse",
    "recommendedAgentAction",
    "relatedRepos",
    "searchText",
    "license",
    "maintenance",
    "qualitySignals",
    "notes"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "repo": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "url": { "type": "string", "minLength": 1 },
    "entryPath": { "type": "string", "minLength": 1 },
    "category": {
      "type": "string",
      "enum": [
        "ui-components",
        "design-systems",
        "react-source-maps",
        "agent-frameworks",
        "mcp-tools",
        "local-dev-infrastructure",
        "automation-tools",
        "data-viz",
        "forms",
        "tables-grids",
        "charts",
        "video-generation",
        "code-quality",
        "testing",
        "documentation",
        "project-management",
        "security",
        "research-reference",
        "hardware-iot",
        "developer-tools",
        "unknown"
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "library",
        "framework",
        "template",
        "design-system",
        "ui-system",
        "tooling",
        "mcp-server",
        "agent-framework",
        "skill-pack",
        "collection",
        "topic-map",
        "reference",
        "implementation-pattern"
      ]
    },
    "aliases": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "stack": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "tags": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "summary": { "type": "string", "minLength": 1 },
    "primaryUseCases": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "agentUseInstruction": { "type": "string", "minLength": 1 },
    "acquisitionMode": {
      "type": "string",
      "enum": [
        "reference-only",
        "reference-map-only",
        "dependency-candidate",
        "template-candidate",
        "fork-candidate",
        "clone-candidate",
        "sandbox-research-only",
        "implementation-pattern",
        "do-not-use"
      ]
    },
    "riskLevel": {
      "type": "string",
      "enum": ["low", "moderate", "high", "critical"]
    },
    "riskFlags": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "riskNotes": { "type": "string", "minLength": 1 },
    "reviewRequiredBeforeUse": { "type": "boolean" },
    "recommendedAgentAction": { "type": "string", "minLength": 1 },
    "relatedRepos": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "searchText": { "type": "string", "minLength": 1 },
    "license": {
      "type": "object",
      "required": ["spdx", "confidence"],
      "properties": {
        "spdx": { "type": "string", "minLength": 1 },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "name": { "type": ["string", "null"] },
        "url": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "maintenance": {
      "type": "object",
      "required": ["state", "notes", "lastReviewedAt"],
      "properties": {
        "state": { "type": "string", "enum": ["active", "slow-moving", "stale", "archived", "unknown"] },
        "notes": { "type": "string", "minLength": 1 },
        "lastReviewedAt": { "type": "string", "minLength": 1 },
        "pushedAt": { "type": ["string", "null"] },
        "updatedAt": { "type": ["string", "null"] },
        "createdAt": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "qualitySignals": {
      "type": "object",
      "required": [
        "stars",
        "forks",
        "watchers",
        "openIssues",
        "archived",
        "disabled",
        "private",
        "fork",
        "visibility",
        "language",
        "topics",
        "homepage",
        "defaultBranch",
        "size",
        "pushedAt",
        "updatedAt",
        "createdAt"
      ],
      "properties": {
        "stars": { "type": "number", "minimum": 0 },
        "forks": { "type": "number", "minimum": 0 },
        "watchers": { "type": "number", "minimum": 0 },
        "openIssues": { "type": "number", "minimum": 0 },
        "archived": { "type": "boolean" },
        "disabled": { "type": "boolean" },
        "private": { "type": "boolean" },
        "fork": { "type": "boolean" },
        "visibility": { "type": "string" },
        "language": { "type": ["string", "null"] },
        "topics": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "homepage": { "type": ["string", "null"] },
        "defaultBranch": { "type": ["string", "null"] },
        "size": { "type": "number", "minimum": 0 },
        "pushedAt": { "type": ["string", "null"] },
        "updatedAt": { "type": ["string", "null"] },
        "createdAt": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "notes": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": false
}

